# Copiá este archivo como ".env" para desarrollo local.
# En Vercel estas variables se cargan en Settings → Environment Variables (SIN prefijo VITE_).

# URL del Worker de Cloudflare (solo el dominio, sin /data.json).
# Ej: https://animales-rescatados-api.TU_SUBDOMINIO.workers.dev
CATALOG_WORKER_URL=

# Secreto HMAC compartido: el MISMO valor en Cloudflare y en Vercel.
DATA_HMAC_SECRET=

# Token de administración: el MISMO valor que el secret ADMIN_TOKEN del Worker.
ADMIN_TOKEN=

# Contraseña que se escribe en /admin para entrar al panel.
ADMIN_PASSWORD=cambia-esta-clave

# Puerto del servidor local de desarrollo (opcional, por defecto 4000).
PORT=4000
